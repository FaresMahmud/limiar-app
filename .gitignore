# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Arquivos de sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# Segredos / variáveis de ambiente (hoje o app é 100% offline e não usa nenhum,
# mas fica a proteção caso algum dia precise)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Rust / Tauri (o src-tauri/.gitignore também cobre /target e /gen/schemas)
src-tauri/target/
src-tauri/gen/

# Instaladores e binários gerados por `tauri build`.
# Ficam em src-tauri/target/release/bundle/, mas costumam ser COPIADOS para outros
# lugares (raiz do projeto) para instalar/testar — por isso ignoramos por extensão
# também, e não só pela pasta. São grandes (MB) e regeneráveis; distribua-os por
# GitHub Releases, nunca versionados no repositório.
bundle/
*.msi
*.exe
*.dmg
*.deb
*.rpm
*.AppImage
*.app.tar.gz

# Artigos/PDFs de referência (copyright — manter local, fora do versionamento)
docs/referencia/*.pdf

# Bancos SQLite locais gerados em runtime (não versionar dados de laboratório)
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal
